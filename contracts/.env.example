# Arc Testnet RPC (re-verify before use)
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# TESTNET-ONLY private key, WITHOUT 0x prefix. Never commit a real key.
PRIVATE_KEY=your_testnet_private_key_without_0x

# Optional override; defaults to the Arc Testnet USDC snapshot in Deploy.s.sol.
# Always confirm at https://docs.arc.io/arc/references/contract-addresses
USDC_ADDRESS=0x3600000000000000000000000000000000000000
