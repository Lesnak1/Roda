# Deployed CircleFactory address on Arc Testnet (fill after `forge script` deploy).
NEXT_PUBLIC_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# Arc Testnet ERC-20 USDC (6 decimals). Verify at:
# https://docs.arc.io/arc/references/contract-addresses
NEXT_PUBLIC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Optional custom RPC (defaults to the public Arc Testnet RPC).
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
